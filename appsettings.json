{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft": "Warning"
    }
  },
  "Manager": {
    "ProcessName": "DNF.exe",
    "ProcessPollSeconds": 2,
    "ActionDelaySeconds": 60,
    "OptimizeGamePriority": true,
    "GamePriority": "AboveNormal",
    "LimitList": [
      "SGuard64.exe",
      "SGuardSvc64.exe",
      "CrossProxy.exe"
    ],
    "KillList": [
      "GameLoader.exe",
      "TXPlatform.exe"
    ],
    "AutoStart": [
      "DNFAutoFire.exe"
    ],
    "AutoStop": [
      "DNFAutoFire.exe"
    ]
  }
}
